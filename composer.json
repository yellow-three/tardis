{
    "name": "yellow-three/tardis",
    "description": "TARDIS Admin Panel Framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "admin", "livewire", "tardis", "bread"],
    "authors": [
        {
            "name": "Yellow Three",
            "email": "hello@yellowthree.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "Tardis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tardis\\TardisServiceProvider"
            ],
            "aliases": {
                "Tardis": "Tardis\\Facades\\Tardis"
            }
        }
    },
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-faker": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-livewire": "^4.1"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "./vendor/bin/pint --test",
        "lint-fix": "./vendor/bin/pint"
    }
}
